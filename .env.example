# Notion API Integration
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID for the Daily SaaS Ideas vault
# Fields: Idea Name (title), Industry (select), Opportunity Score (number),
#         Verdict (select), Status (select), 60-Second Pitch (text),
#         TAM (text), MVP Build Cost (text), Break-Even Customers (text),
#         Date Generated (date)
NOTION_IDEAS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID for blog posts / articles
# Fields: Title (title), Slug (rich_text), Published (checkbox),
#         Date (date), Description (rich_text), Tags (multi_select),
#         Author (rich_text), Cover (files)
NOTION_BLOG_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
