---
export interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;
---

<header class="header" role="banner">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="IdeaBrief home">
      <svg class="header__logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="30" height="30" rx="6" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        <path d="M12 7L10 19h12L20 7H12z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M13.5 19v5h5v-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="16" cy="12.5" r="2.5" fill="currentColor" opacity="0.9"/>
        <line x1="16" y1="6" x2="16" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
        <line x1="22" y1="9" x2="24.5" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
        <line x1="10" y1="9" x2="7.5" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
      </svg>
      <span class="header__logo-text">IdeaBrief</span>
    </a>
    <nav class="header__nav" aria-label="Main navigation">
      <div class="header__nav-links">
        <a href="/#how-it-works" class="header__link">How It Works</a>
        <a href="/#pricing" class="header__link">Pricing</a>
        <a href="/#vault" class="header__link">Idea Vault</a>
        <a href="/blog/" class:list={['header__link', { 'header__link--active': currentPage === 'blog' }]}>Blog</a>
      </div>
      <a href="/#subscribe" class="header__cta">Subscribe Free</a>
    </nav>
  </div>
</header>
