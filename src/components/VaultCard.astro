---
export interface Props {
  name: string;
  industry: string;
  pitch: string;
  score: string;
  verdict?: string;
}

const { name, industry, pitch, score, verdict = 'Conditions' } = Astro.props;
---

<div class="vault-card">
  <div class="vault-card__info">
    <div class="vault-card__name">{name}</div>
    <div class="vault-card__industry">{industry}</div>
    <div class="vault-card__pitch">{pitch}</div>
  </div>
  <div class="vault-card__meta">
    <div class="vault-card__score">{score}</div>
    <span class={`badge badge--${verdict.toLowerCase() === 'go' ? 'go' : 'conditions'}`}>{verdict}</span>
  </div>
</div>
