---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { initNotion, getPublishedPosts } from '../../lib/notion';

initNotion({
  token: import.meta.env.NOTION_TOKEN || '',
  ideasDb: import.meta.env.NOTION_IDEAS_DB || '',
  blogDb: import.meta.env.NOTION_BLOG_DB || '',
});
const posts = await getPublishedPosts();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'IdeaBrief Blog',
  description: 'Insights and updates on AI-validated startup ideas, market analysis, and building in underserved industries.',
  url: 'https://ideabrief.ai/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'IdeaBrief',
    url: 'https://ideabrief.ai',
  },
  creator: {
    '@type': 'SoftwareApplication',
    name: 'Perplexity Computer',
    url: 'https://www.perplexity.ai/computer',
  },
};
---

<BaseLayout
  title="Blog"
  description="Insights and updates on AI-validated startup ideas, market analysis, and building in underserved industries."
  canonical="https://ideabrief.ai/blog/"
  ogType="website"
  jsonLd={jsonLd}
  currentPage="blog"
>

<section class="section blog-listing">
  <div class="container">
    <div style="text-align:center;">
      <span class="section-label">Blog</span>
      <h1 class="section-title">Insights & Updates</h1>
      <p class="section-subtitle" style="margin-inline:auto;">Deep dives into startup validation, market opportunities, and the art of building in underserved industries.</p>
    </div>

    {posts.length > 0 ? (
      <div class="blog-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.title}
            slug={post.slug}
            date={post.date}
            description={post.description}
            tags={post.tags}
            coverImage={post.coverImage || undefined}
          />
        ))}
      </div>
    ) : (
      <div class="blog-empty">
        <div class="blog-empty__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <h3 class="blog-empty__title">Blog posts coming soon</h3>
        <p class="blog-empty__text">We're working on insightful content about startup validation, AI tools, and building in underserved markets. Subscribe to get notified.</p>
        <a href="/#subscribe" class="blog-empty__cta">Subscribe Free</a>
      </div>
    )}
  </div>
</section>

</BaseLayout>

<style>
  .blog-listing {
    min-height: 60vh;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  .blog-empty {
    text-align: center;
    padding: var(--space-16) var(--space-6);
    max-width: 480px;
    margin-inline: auto;
    margin-top: var(--space-8);
  }

  .blog-empty__icon {
    width: 48px;
    height: 48px;
    margin-inline: auto;
    margin-bottom: var(--space-5);
    color: var(--color-text-faint);
  }

  .blog-empty__icon svg {
    width: 100%;
    height: 100%;
  }

  .blog-empty__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .blog-empty__text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }

  .blog-empty__cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: #0a0a0f;
    font-size: var(--text-sm);
    font-weight: 700;
    font-family: var(--font-display);
    text-decoration: none;
    transition: background var(--transition-interactive),
                transform var(--transition-interactive),
                box-shadow var(--transition-interactive);
  }

  .blog-empty__cta:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
  }
</style>
